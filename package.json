{
  "name": "pmu-registration-monorepo",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm --prefix frontend run dev\" \"npm --prefix backend run dev\"",
    "dev:all": "npm run dev",
    "frontend:dev": "npm --prefix frontend run dev",
    "backend:dev": "npm --prefix backend run dev",
    "build": "npm --prefix frontend run build",
    "db:migrate": "npm --prefix backend run db:migrate",
    "db:seed": "npm --prefix backend run db:seed"
  },
  "dependencies": {
    "concurrently": "^9.2.1"
  }
}
